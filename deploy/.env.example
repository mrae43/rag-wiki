# =============================================================================
# Stage-1 production environment — Compose-on-VM, trusted-clients-only.
# ADR-0017 / PRD-002.
# =============================================================================
#
# Copy to `.env` in THIS directory (deploy/) and fill in every REQUIRED
# value. Compose auto-discovers `./.env` for `${VAR}` interpolation in
# docker-compose.prod.yml, and the api/worker services load the same file
# into their environment via `env_file:`.
#
# `DATABASE_URL` is NOT set here — it is assembled by docker-compose.prod.yml
# from POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB + the `db` service
# host. Set one DB secret, not a connection string.

# =============================================================================
# Deploy (REQUIRED)
# =============================================================================
# GHCR owner/namespace the image is pushed to by CI
# (`${{ github.repository_owner }}` in CI; set the matching owner here).
GHCR_OWNER=

# Image tag to pull. Pin to a sha tag for reproducible deploys:
#   IMAGE_TAG=sha-a1b2c3d
# or use `latest` for convenience. Rollback = edit this line + `up -d`.
IMAGE_TAG=latest

# Tailscale tailnet host (the MagicDNS suffix), e.g. `example.ts.net`.
# The site is served at `https://rag-wiki.<TAILNET_HOST>`.
TAILNET_HOST=

# =============================================================================
# Database (REQUIRED)
# =============================================================================
# Stage-1 uses the `ragwiki` user/db (distinct from dev's `rag_wiki`).
POSTGRES_USER=ragwiki
POSTGRES_DB=ragwiki

# REQUIRED. Generate a strong secret, e.g. `openssl rand -base64 32`.
POSTGRES_PASSWORD=

# =============================================================================
# LLM provider (REQUIRED unless pointing at a no-auth local endpoint)
# =============================================================================
# Valid values: openai | anthropic
# For Azure OpenAI, vLLM, or Ollama, use "openai" and set LLM_BASE_URL.
LLM_PROVIDER=openai

# REQUIRED for any non-local provider.
LLM_API_KEY=

# Base URL override for OpenAI-compatible endpoints (Azure, vLLM, Ollama, NIM).
# Examples:
#   Azure OpenAI: https://your-resource.openai.azure.com/
#   vLLM:         http://localhost:8000/v1
#   Ollama:       http://localhost:11434/v1
LLM_BASE_URL=

# Azure OpenAI API version (only needed when using Azure OpenAI).
LLM_API_VERSION=

# =============================================================================
# Per-operation model selection
# =============================================================================
LLM_MODEL_CAPTION=gpt-4o-mini
LLM_MODEL_EXTRACTION=gpt-4o-mini
LLM_MODEL_RESOLUTION=gpt-4o
LLM_MODEL_WIKI_SYNTHESIS=gpt-4o
LLM_MODEL_QUERY=gpt-4o
LLM_MODEL_QUERY_CLASSIFICATION=gpt-4o-mini

# =============================================================================
# Embeddings
# =============================================================================
# Valid values: openai | googleai
LLM_EMBEDDING_PROVIDER=openai

# Must match the model used to produce vectors stored in pgvector.
EMBEDDING_MODEL=gemini-embedding-2

# Whether to send the `dimensions` param to the embedding API.
# Disable for providers that don't support it (NVIDIA NIM, Ollama, vLLM).
SEND_DIMENSIONS=true

# Must match the model's output size.
#   text-embedding-3-small: 1536
#   text-embedding-3-large: 3072
#   gemini-embedding-2:     3072
EMBEDDING_DIMENSIONS=3072

# Google AI API key (only needed when LLM_EMBEDDING_PROVIDER=googleai).
# Falls back to LLM_API_KEY if not set.
GEMINI_API_KEY=

# Task type for Google AI embeddings (only used when provider=googleai).
EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT

# =============================================================================
# Entity resolution
# =============================================================================
ENTITY_RESOLUTION_TOP_K=5
ENTITY_RESOLUTION_DISTANCE_THRESHOLD=0.6

# =============================================================================
# Planner
# =============================================================================
PLANNER_VERSION=1.0.0
PLANNER_CONFIDENCE_HIGH=0.8
PLANNER_CONFIDENCE_LOW=0.5
PLANNER_CONFIDENCE_MINIMUM=0.5
PLANNER_DENSITY_LARGE_THRESHOLD_BYTES=10485760
PLANNER_QUERY_CLASSIFICATION_TIMEOUT_MS=500

# =============================================================================
# Worker
# =============================================================================
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_MAX_RETRIES=3

# =============================================================================
# API
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
UPLOAD_MAX_FILE_SIZE_BYTES=104857600

# LOCKED in Stage-1 (PRD-002 §11). The future Interface App calls
# server-side, so CORS is irrelevant. Leave empty until an explicit origin
# is allow-listed. Do NOT change this to a wildcard.
CORS_ORIGINS=""

# =============================================================================
# Storage provider
# =============================================================================
# Stage-1 ships local-filesystem storage. STORAGE_PROVIDER and UPLOAD_DIR are
# set by docker-compose.prod.yml (named volume); do not override them here
# unless moving to S3 (Stage-2 additive: new SeaweedFS service block + the
# values below).
S3_BUCKET=rag-wiki
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# =============================================================================
# Retrieval
# =============================================================================
RETRIEVAL_SEED_COUNT=3
RETRIEVAL_MAX_HOPS=2
RETRIEVAL_MAX_NEIGHBORS_PER_HOP=10
RETRIEVAL_MAX_TOTAL_NODES=50
RETRIEVAL_DEDUP_THRESHOLD=0.92
RETRIEVAL_TOTAL_BUDGET_TOKENS=3600
RETRIEVAL_ANCHOR_BUDGET_TOKENS=200
RETRIEVAL_SUBGRAPH_BUDGET_TOKENS=400
RETRIEVAL_WIKI_PAGE_BUDGET_TOKENS=1000
RETRIEVAL_INSTRUCTION_BUDGET_TOKENS=200

# =============================================================================
# MCP server (operator's laptop, not the VM)
# =============================================================================
# No MCP service runs in prod compose (ADR-0017 §6). The operator runs
# `rag-wiki mcp serve` locally on their own machine over stdio, pointing at
# the deployed API over Tailscale:
#   RAG_WIKI_MCP_TRANSPORT=stdio
#   RAG_WIKI_MCP_API_URL=https://rag-wiki.<tailnet>
# These values are listed for reference; they are not consumed by the VM
# services.
MCP_TRANSPORT=stdio
MCP_API_URL=http://127.0.0.1:8000
# Must be loopback (127.0.0.1, ::1, localhost) when MCP_TRANSPORT=http —
# the Settings model_validator rejects any other value (ADR-0017 §6).
MCP_HOST=127.0.0.1
# MCP_PORT=

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
# Options: json | console
LOG_FORMAT=console

# =============================================================================
# pgvector HNSW index settings
# =============================================================================
HNSW_M=24
HNSW_EF_CONSTRUCTION=200
