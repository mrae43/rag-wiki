# LLM RAG Wiki — environment configuration
#
# Copy this file to `.env` and fill in your values.
# All configuration is loaded via pydantic-settings (12-factor style).
# No secrets or URLs are hardcoded in source code.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# Example (Docker Compose default): postgresql+asyncpg://rag_wiki:rag_wiki@db:5432/rag_wiki
DATABASE_URL=

# PostgreSQL credentials (used by docker-compose db service).
# These must match the values in DATABASE_URL.
POSTGRES_USER=rag_wiki
POSTGRES_PASSWORD=rag_wiki
POSTGRES_DB=rag_wiki

# pgAdmin credentials (dev-only tool, started with `docker compose --profile dev-tools up`).
# Copy pgadmin/servers.example.json to pgadmin/servers.json and update the values.
# The Postgres password is entered once on first pgAdmin connection.
PGADMIN_DEFAULT_EMAIL=admin@rag-wiki.local
PGADMIN_DEFAULT_PASSWORD=admin

# LLM provider. Valid values: openai | anthropic
# For Azure OpenAI, vLLM, or Ollama, use "openai" and set LLM_BASE_URL below.
LLM_PROVIDER=openai

# API key for the chosen LLM provider.
# Not required for some local/self-hosted endpoints (e.g. Ollama without auth).
LLM_API_KEY=

# ---------------------------------------------------------------------------
# Optional — LLM provider overrides
# ---------------------------------------------------------------------------

# Base URL override for OpenAI-compatible endpoints.
# Use this for Azure OpenAI, vLLM, Ollama, or NVIDIA NIM.
# Examples:
#   Azure OpenAI: https://your-resource.openai.azure.com/
#   vLLM:         http://localhost:8000/v1
#   Ollama:       http://localhost:11434/v1
#   NVIDIA NIM:   https://integrate.api.nvidia.com/v1
LLM_BASE_URL=

# Azure OpenAI API version (only needed when using Azure OpenAI).
# Example: 2024-06-01
LLM_API_VERSION=

# ---------------------------------------------------------------------------
# Optional — Per-operation model selection
# ---------------------------------------------------------------------------

# Model used for captioning images and tables (cheap/fast is fine).
LLM_MODEL_CAPTION=gpt-4o-mini

# Model used for entity/relation extraction from chunks.
LLM_MODEL_EXTRACTION=gpt-4o-mini

# Model used for merge-vs-new entity resolution decisions.
LLM_MODEL_RESOLUTION=gpt-4o

# Model used for synthesizing and updating wiki pages (stronger model recommended).
LLM_MODEL_WIKI_SYNTHESIS=gpt-4o

# Model used for answering queries from the wiki + graph.
LLM_MODEL_QUERY=gpt-4o

# ---------------------------------------------------------------------------
# Optional — Embeddings
# ---------------------------------------------------------------------------

# Embedding provider. Defaults to "openai".
# Set this explicitly if you use a different provider for embeddings (e.g.
# Anthropic for chat but OpenAI for embeddings).
# Valid values: openai (covers all OpenAI-compatible endpoints)
LLM_EMBEDDING_PROVIDER=openai

# Embedding model name. Must match the model used to produce vectors
# stored in the pgvector `embedding` column.
EMBEDDING_MODEL=text-embedding-3-small

# Whether to send the `dimensions` parameter to the embedding API.
# OpenAI's text-embedding-3-* models support this (truncates vectors server-side).
# Disable for providers that don't support it (NVIDIA NIM, Ollama, vLLM).
# Example: SEND_DIMENSIONS=false
SEND_DIMENSIONS=true

# Embedding vector dimensions. Must match the model's output size.
#   text-embedding-3-small: 1536
#   text-embedding-3-large: 3072
#   gemini-embedding-2: 3072 (current default)
EMBEDDING_DIMENSIONS=3072

# ---------------------------------------------------------------------------
# Optional — Entity resolution
# ---------------------------------------------------------------------------

# Max number of existing entity candidates to send to the LLM for merge review.
ENTITY_RESOLUTION_TOP_K=5

# Max embedding distance for a candidate to be considered similar.
# Lower = stricter matching. Range: 0.0–2.0 for cosine distance.
ENTITY_RESOLUTION_DISTANCE_THRESHOLD=0.6

# ---------------------------------------------------------------------------
# Optional — Parsing
# ---------------------------------------------------------------------------

# Parser backend. Valid values: lightweight | mineru
#   lightweight — PyMuPDF + unstructured (default, no extra deps)
#   mineru      — GPU-accelerated full multimodal (requires `uv pip install rag-wiki[mineru]`)
PARSER=lightweight


# ── Job worker ───────────────────────────────────────────────
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_MAX_RETRIES=3

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Retrieval ────────────────────────────────────────────────
# Number of seed entities from vector search.
RETRIEVAL_SEED_COUNT=3
# Graph traversal depth (hops).
RETRIEVAL_MAX_HOPS=2
# Max neighbors expanded per hop.
RETRIEVAL_MAX_NEIGHBORS_PER_HOP=10
# Max unique entities after truncation.
RETRIEVAL_MAX_TOTAL_NODES=50
# Cosine similarity threshold for chunk deduplication (0.0–1.0).
RETRIEVAL_DEDUP_THRESHOLD=0.92
# Default total token budget for context assembly.
RETRIEVAL_TOTAL_BUDGET_TOKENS=3600
# Per-slot fixed budgets (tokens).
RETRIEVAL_ANCHOR_BUDGET_TOKENS=200
RETRIEVAL_SUBGRAPH_BUDGET_TOKENS=400
RETRIEVAL_WIKI_PAGE_BUDGET_TOKENS=1000
RETRIEVAL_INSTRUCTION_BUDGET_TOKENS=200

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: json | console
LOG_FORMAT=console
